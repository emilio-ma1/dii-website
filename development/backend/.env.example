# ==========================================
# Configuración del Servidor (Server Config)
# ==========================================
# Puerto en el que se ejecutará la API de Express
PORT=

# URL del Frontend para habilitar los permisos de CORS
FRONTEND_URL=

# ==========================================
# Configuración de Seguridad (Security Config)
# ==========================================
# Clave secreta para firmar los tokens JWT
JWT_SECRET=

# ==========================================
# Configuración de Base de Datos (Database Config)
# ==========================================
# Credenciales para la conexión a PostgreSQL
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Configuración JWT Temporal para 2FA
JWT_TEMP_SECRET=firma_super_secreta_para_tokens_temporales_2fa
JWT_TEMP_EXPIRES_IN=10m

# Configuración del Servidor de Correos (SMTP)
# (Puedes usar Gmail, SendGrid, Outlook, o Mailtrap para pruebas)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo_del_departamento@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion_aqui